/// Produits stickers créés par les vendeurs
model StickerProduct {
  id Int @id @default(autoincrement())

  // Références
  vendorId Int @map("vendor_id")
  designId Int @map("design_id")

  // Informations du produit
  name               String  @db.VarChar(255)
  description        String? @db.Text
  sku                String? @unique @db.VarChar(100)
  imageUrl           String? @map("image_url") @db.VarChar(500)
  cloudinaryPublicId String? @map("cloudinary_public_id") @db.VarChar(255)

  // Configuration du sticker
  sizeId   String       @map("size_id") @db.VarChar(50)
  widthCm  Decimal      @map("width_cm") @db.Decimal(10, 2)
  heightCm Decimal      @map("height_cm") @db.Decimal(10, 2)
  finish   String       @db.VarChar(50)
  shape    StickerShape @default(SQUARE)

  // Prix et quantités
  basePrice        Int     @map("base_price")
  finishMultiplier Decimal @default(1.00) @map("finish_multiplier") @db.Decimal(3, 2)
  finalPrice       Int     @map("final_price")
  minQuantity      Int     @default(1) @map("min_quantity")
  maxQuantity      Int     @default(100) @map("max_quantity")

  // Configuration de génération d'image
  stickerType String? @map("sticker_type") @db.VarChar(50) // 'autocollant' | 'pare-chocs'
  borderColor String? @map("border_color") @db.VarChar(50) // 'glossy-white' | 'white' | 'matte-white' | 'transparent'
  surface     String? @map("surface") @db.VarChar(50) // 'blanc-mat' | 'transparent'

  // Métadonnées
  status     StickerProductStatus @default(DRAFT)
  isFeatured Boolean              @default(false) @map("is_featured")
  viewCount  Int                  @default(0) @map("view_count")
  saleCount  Int                  @default(0) @map("sale_count")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  publishedAt DateTime? @map("published_at")

  // Relations
  vendor         User               @relation("VendorStickers", fields: [vendorId], references: [id], onDelete: Cascade)
  design         Design             @relation("StickerDesigns", fields: [designId], references: [id], onDelete: Cascade)
  orderItems     StickerOrderItem[]
  orderLineItems OrderItem[]        @relation("StickerOrderItems")
  views          StickerView[]
  favorites      StickerFavorite[]

  @@index([vendorId])
  @@index([designId])
  @@index([status])
  @@index([sizeId])
  @@index([finish])
  @@index([isFeatured])
  @@index([publishedAt])
  @@map("sticker_products")
}

/// Items de commande pour les stickers
model StickerOrderItem {
  id               Int @id @default(autoincrement())
  orderId          Int @map("order_id")
  stickerProductId Int @map("sticker_product_id")

  // Détails de la commande
  quantity   Int
  unitPrice  Int @map("unit_price")
  totalPrice Int @map("total_price")

  // Configuration (snapshot au moment de la commande)
  sizeName     String? @map("size_name") @db.VarChar(100)
  finishName   String? @map("finish_name") @db.VarChar(100)
  shapeName    String? @map("shape_name") @db.VarChar(100)
  dimensionsCm String? @map("dimensions_cm") @db.VarChar(50)

  // Métadonnées
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  stickerProduct StickerProduct @relation(fields: [stickerProductId], references: [id])

  @@index([orderId])
  @@index([stickerProductId])
  @@map("sticker_order_items")
}

/// Analytics - Vues de stickers
model StickerView {
  id        Int      @id @default(autoincrement())
  stickerId Int      @map("sticker_id")
  userId    Int?     @map("user_id")
  sessionId String?  @map("session_id") @db.VarChar(255)
  viewedAt  DateTime @default(now()) @map("viewed_at")

  sticker StickerProduct @relation(fields: [stickerId], references: [id], onDelete: Cascade)

  @@index([stickerId])
  @@index([viewedAt])
  @@map("sticker_views")
}

/// Analytics - Favoris de stickers
model StickerFavorite {
  id        Int      @id @default(autoincrement())
  stickerId Int      @map("sticker_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")

  sticker StickerProduct @relation(fields: [stickerId], references: [id], onDelete: Cascade)
  user    User           @relation("UserStickerFavorites", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([stickerId, userId], name: "unique_sticker_favorite")
  @@index([stickerId])
  @@index([userId])
  @@map("sticker_favorites")
}

