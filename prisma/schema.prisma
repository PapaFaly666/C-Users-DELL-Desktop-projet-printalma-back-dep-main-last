/// 13 Régions du Sénégal (hors Dakar)
model DeliveryRegion {
  id               String   @id @default(uuid())
  name             String   @unique
  status           String   @default("active")
  price            Decimal  @db.Decimal(10, 2)
  deliveryTimeMin  Int      @map("delivery_time_min")
  deliveryTimeMax  Int      @map("delivery_time_max")
  deliveryTimeUnit String   @default("jours") @map("delivery_time_unit")
  mainCities       String?  @map("main_cities")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@map("delivery_regions")
}

/// Zones Internationales
model DeliveryInternationalZone {
  id              String                         @id @default(uuid())
  name            String
  status          String                         @default("active")
  price           Decimal                        @db.Decimal(10, 2)
  deliveryTimeMin Int                            @map("delivery_time_min")
  deliveryTimeMax Int                            @map("delivery_time_max")
  createdAt       DateTime                       @default(now()) @map("created_at")
  updatedAt       DateTime                       @updatedAt @map("updated_at")
  countries       DeliveryInternationalCountry[]
  tarifs          DeliveryZoneTarif[]

  @@index([status])
  @@map("delivery_international_zones")
