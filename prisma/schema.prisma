/// Pays des Zones Internationales
model DeliveryInternationalCountry {
  id      Int                       @id @default(autoincrement())
  zoneId  String                    @map("zone_id")
  country String
  zone    DeliveryInternationalZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@map("delivery_international_countries")
}

/// Transporteurs
model DeliveryTransporteur {
  id        String                     @id @default(uuid())
  name      String
  logoUrl   String?                    @map("logo_url") @db.VarChar(500)
  status    String                     @default("active")
  createdAt DateTime                   @default(now()) @map("created_at")
  updatedAt DateTime                   @updatedAt @map("updated_at")
  zones     DeliveryTransporteurZone[]
  tarifs    DeliveryZoneTarif[]

  @@index([status])
  @@map("delivery_transporteurs")
}

/// Zones de Livraison des Transporteurs
/// Note: zoneId est polymorphe et référence soit une city, region, ou international zone
model DeliveryTransporteurZone {
  id             Int                  @id @default(autoincrement())
  transporteurId String               @map("transporteur_id")
  zoneId         String               @map("zone_id")
  zoneType       String               @map("zone_type")
  transporteur   DeliveryTransporteur @relation(fields: [transporteurId], references: [id], onDelete: Cascade)

  @@index([transporteurId])
  @@index([zoneId, zoneType])
  @@map("delivery_transporteur_zones")
}

/// Tarifs par Zone et Transporteur
model DeliveryZoneTarif {
  id                        String                    @id @default(uuid())
  zoneId                    String                    @map("zone_id")
  zoneName                  String                    @map("zone_name")
  transporteurId            String                    @map("transporteur_id")
  transporteurName          String                    @map("transporteur_name")
  prixTransporteur          Decimal                   @map("prix_transporteur") @db.Decimal(10, 2)
  prixStandardInternational Decimal                   @map("prix_standard_international") @db.Decimal(10, 2)
  delaiLivraisonMin         Int                       @map("delai_livraison_min")
  delaiLivraisonMax         Int                       @map("delai_livraison_max")
  status                    String                    @default("active")
  createdAt                 DateTime                  @default(now()) @map("created_at")
  updatedAt                 DateTime                  @updatedAt @map("updated_at")
  transporteur              DeliveryTransporteur      @relation(fields: [transporteurId], references: [id], onDelete: Cascade)
  internationalZone         DeliveryInternationalZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)

  @@index([zoneId])
  @@index([transporteurId])
  @@index([status])
  @@map("delivery_zone_tarifs")
}

model CategoryToProduct {
  A          Int
  B          Int
  categories Category @relation(fields: [A], references: [id], onDelete: Cascade)
  Product    Product  @relation(fields: [B], references: [id], onDelete: Cascade)

  @@id([A, B], map: "_CategoryToProduct_AB_pkey")
  @@index([B], map: "_CategoryToProduct_B_index")
  @@map("_CategoryToProduct")
}

/// Galeries de vendeurs - Système de présentation de portfolios
/// Chaque vendeur peut avoir au maximum une galerie active
model VendorGallery {
  id          Int            @id @default(autoincrement())
  vendorId    Int            @unique @map("vendor_id")
  title       String         @db.VarChar(100)
  description String?        @db.VarChar(500)
  status      GalleryStatus  @default(DRAFT)
  isPublished Boolean        @default(false) @map("is_published")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")
  deletedAt   DateTime?      @map("deleted_at")
  vendor      User           @relation("VendorGalleries", fields: [vendorId], references: [id], onDelete: Cascade)
  images      GalleryImage[]

  @@index([status])
  @@index([createdAt])
  @@index([isPublished])
  @@index([vendorId, deletedAt], map: "idx_vendor_gallery_lookup")
  @@index([isPublished, status, deletedAt], map: "idx_public_galleries")
  @@map("vendor_galleries")
}

/// Images des galeries - Exactement 5 images par galerie
model GalleryImage {
  id            Int           @id @default(autoincrement())
  galleryId     Int           @map("gallery_id")
  imageUrl      String        @map("image_url") @db.VarChar(500)
  imagePath     String        @map("image_path") @db.VarChar(500)
  publicId      String        @map("public_id") @db.VarChar(255)
  caption       String?       @db.VarChar(200)
  orderPosition Int           @map("order_position")
  fileSize      Int           @map("file_size")
  mimeType      String        @map("mime_type") @db.VarChar(50)
  width         Int?
  height        Int?
  createdAt     DateTime      @default(now()) @map("created_at")
  gallery       VendorGallery @relation(fields: [galleryId], references: [id], onDelete: Cascade)

  @@unique([galleryId, orderPosition], name: "unique_gallery_order")
  @@index([galleryId])
  @@index([galleryId, orderPosition])
  @@map("gallery_images")
}

/// 🆕 Suivi des utilisations de designs vendeurs pour le calcul des revenus
/// Enregistre chaque fois qu'un client utilise un design vendeur dans une commande
model DesignUsage {
  id Int @id @default(autoincrement())

  // Informations sur le design
  designId    Int     @map("design_id")
  designName  String  @map("design_name") @db.VarChar(255)
  designPrice Decimal @map("design_price") @db.Decimal(10, 2)

  // Informations sur le vendeur
  vendorId Int @map("vendor_id")

  // Informations sur la commande
  orderId     Int    @map("order_id")
  orderNumber String @map("order_number") @db.VarChar(50)
  orderItemId Int    @map("order_item_id")

  // Informations sur le client
  customerName  String  @map("customer_name") @db.VarChar(255)
  customerEmail String? @map("customer_email") @db.VarChar(255)

  // Informations sur le produit
  productId   Int    @map("product_id")
  productName String @map("product_name") @db.VarChar(255)

  // Calcul des revenus
  commissionRate Decimal @default(70.00) @map("commission_rate") @db.Decimal(5, 2)
  vendorRevenue  Decimal @map("vendor_revenue") @db.Decimal(10, 2)
  platformFee    Decimal @map("platform_fee") @db.Decimal(10, 2)

  // Statut de paiement
  paymentStatus DesignUsagePaymentStatus @default(PENDING) @map("payment_status")

  // Dates importantes
  usedAt           DateTime  @default(now()) @map("used_at")
  confirmedAt      DateTime? @map("confirmed_at")
  readyForPayoutAt DateTime? @map("ready_for_payout_at")
  paidAt           DateTime? @map("paid_at")

  // Métadonnées
  customizationId Int?    @map("customization_id")
  viewKey         String? @map("view_key") @db.VarChar(50)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  design    Design    @relation(fields: [designId], references: [id], onDelete: Cascade)
  vendor    User      @relation("VendorDesignUsages", fields: [vendorId], references: [id], onDelete: Cascade)
  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)

  @@unique([designId, orderItemId], name: "unique_design_order_item")
  @@index([vendorId, paymentStatus], name: "idx_vendor_payment_status")
  @@index([orderId], name: "idx_order_id")
  @@index([designId], name: "idx_design_id")
  @@map("design_usages")
}

/// 🔒 Table de sécurité des numéros de téléphone vendeur
/// Système de vérification OTP + Email + Période de sécurité 48h
model VendorPhoneNumber {
  id       Int @id @default(autoincrement())
  vendorId Int @map("vendor_id")

  // Informations du numéro
  countryCode String  @default("+221") @map("country_code") @db.VarChar(5)
  phoneNumber String  @map("phone_number") @db.VarChar(20)
  isPrimary   Boolean @default(false) @map("is_primary")

  // Sécurité
  isVerified Boolean           @default(false) @map("is_verified")
  verifiedAt DateTime?         @map("verified_at")
  status     PhoneNumberStatus @default(PENDING)

  // Période de sécurité (48h après vérification)
  securityHoldUntil DateTime? @map("security_hold_until")

  // Métadonnées
  addedAt               DateTime  @default(now()) @map("added_at")
  lastUsedForWithdrawal DateTime? @map("last_used_for_withdrawal")

  // Relations
  vendor User @relation("VendorPhoneNumbers", fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, phoneNumber], name: "unique_vendor_phone_number")
  @@index([vendorId])
  @@index([status])
  @@index([vendorId, isPrimary])
  @@map("vendor_phone_numbers")
}

/// 🔐 Table des codes OTP pour vérification des téléphones
model PhoneOTPCode {
  id          Int    @id @default(autoincrement())
  vendorId    Int    @map("vendor_id")
  phoneNumber String @map("phone_number") @db.VarChar(20)

  // Code OTP
  code     String @db.VarChar(6)
  codeHash String @map("code_hash") @db.VarChar(255)

  // Expiration
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime @map("expires_at")

  // Statut
  isUsed     Boolean   @default(false) @map("is_used")
  verifiedAt DateTime? @map("verified_at")
  attempts   Int       @default(0)

  // Sécurité
  ipAddress String? @map("ip_address") @db.VarChar(45)
  userAgent String? @map("user_agent") @db.Text

  // Relations
  vendor User @relation("VendorPhoneOTPs", fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([expiresAt])
  @@index([isUsed])
  @@map("phone_otp_codes")
}

/// 📝 Logs de sécurité pour traçabilité
model SecurityLog {
  id       Int @id @default(autoincrement())
  vendorId Int @map("vendor_id")

  // Action
  action String @db.VarChar(50)
  // 'PHONE_ADDED', 'PHONE_VERIFIED', 'PHONE_DELETED',
  // 'OTP_SENT', 'OTP_VERIFIED', 'OTP_FAILED',
  // 'WITHDRAWAL_ATTEMPTED', 'WITHDRAWAL_BLOCKED'

  // Détails
  phoneNumber String? @map("phone_number") @db.VarChar(20)
  details     Json?

  // Contexte
  ipAddress String?  @map("ip_address") @db.VarChar(45)
  userAgent String?  @map("user_agent") @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  vendor User @relation("VendorSecurityLogs", fields: [vendorId], references: [id], onDelete: Cascade)

  @@index([vendorId])
  @@index([action])
  @@index([createdAt])
  @@map("security_logs")
}

/// ⚠️ DEPRECATED: Ancienne table VendorPhone (à supprimer après migration)
model VendorPhone {
