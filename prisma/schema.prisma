/// Système de commission vendeur - Table principale
model VendorCommission {
  id                  Int                  @id @default(autoincrement()) @map("id")
  vendorId            Int                  @unique @map("vendor_id")
  commissionRate      Float                @default(40.00) @map("commission_rate")
