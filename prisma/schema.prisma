/// 🔒 Statut des numéros de téléphone vendeur
enum PhoneNumberStatus {
  PENDING // En attente de vérification ou en période de sécurité
  ACTIVE // Actif et utilisable pour retraits
  SUSPENDED // Suspendu (comportement suspect)
}

/// 🔧 Configuration dynamique des fournisseurs de paiement
/// Permet aux admins de gérer les clés API sans toucher au code
/// Chaque provider a UN enregistrement avec les clés TEST et LIVE
model PaymentConfig {
  id       Int    @id @default(autoincrement())
  provider String @unique @db.VarChar(50) // 'paydunya', 'paytech', etc.

  // Configuration active
  isActive   Boolean @default(true) @map("is_active")
  activeMode String  @default("test") @map("active_mode") @db.VarChar(10) // 'test' ou 'live'

  // Clés API TEST
  testMasterKey  String? @map("test_master_key") @db.VarChar(255)
  testPrivateKey String? @map("test_private_key") @db.VarChar(255)
  testToken      String? @map("test_token") @db.VarChar(255)
  testPublicKey  String? @map("test_public_key") @db.VarChar(255)

  // Clés API LIVE
  liveMasterKey  String? @map("live_master_key") @db.VarChar(255)
  livePrivateKey String? @map("live_private_key") @db.VarChar(255)
  liveToken      String? @map("live_token") @db.VarChar(255)
  livePublicKey  String? @map("live_public_key") @db.VarChar(255)

  // Configuration additionnelle
  webhookSecret String? @map("webhook_secret") @db.VarChar(255)
  metadata      Json?   @default("{}")

  // Timestamps
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([provider])
  @@index([isActive])
  @@index([activeMode])
  @@map("payment_configs")
}

/// 🔐 OTP pour authentification à deux facteurs (2FA)
/// Code envoyé par email lors du login pour les admins et vendeurs
model LoginOTP {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  code      String    @db.VarChar(6) // Code à 6 chiffres
  expiresAt DateTime  @map("expires_at")
  verified  Boolean   @default(false)
  attempts  Int       @default(0) // Nombre de tentatives
  ipAddress String?   @map("ip_address") @db.VarChar(50)
  userAgent String?   @map("user_agent") @db.Text
  createdAt DateTime  @default(now()) @map("created_at")
  usedAt    DateTime? @map("used_at")

  user User @relation("UserLoginOTPs", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([code])
  @@index([expiresAt])
  @@index([verified])
  @@map("login_otps")
}

/// 🔧 Paramètres globaux de l'application
/// Stocke toutes les configurations modifiables par les administrateurs
model AppSettings {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100) // Clé unique du paramètre
  value     String?  @db.Text // Valeur du paramètre (stockée en texte, peut être JSON)
  dataType  String   @default("string") @db.VarChar(20) // string, number, boolean, json
  category  String?  @db.VarChar(50) // Pour grouper les paramètres (company, vendors, email, etc.)
  updatedBy Int?     @map("updated_by") // ID de l'admin qui a fait la mise à jour
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  admin User? @relation("AppSettingsUpdater", fields: [updatedBy], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([category])
  @@map("app_settings")
}
