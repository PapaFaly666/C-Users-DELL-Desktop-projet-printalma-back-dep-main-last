# Database Configuration
DATABASE_URL="postgresql://printalma_user:printalma_password@localhost:5432/printalma_db?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# SMTP Configuration for emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Redis Configuration
REDIS_PASSWORD="redis_password"

# Application Configuration
NODE_ENV="development"
PORT="3000"

# Security
CORS_ORIGIN="http://localhost:3000"

# PayTech Payment Gateway Configuration (DEPRECATED - Use PayDunya instead)
# Documentation: https://doc.intech.sn/doc_paytech.php
PAYTECH_API_KEY="your-paytech-api-key"
PAYTECH_API_SECRET="your-paytech-api-secret"
PAYTECH_ENVIRONMENT="test"
# Note: IPN URL must be HTTPS in production
PAYTECH_IPN_URL="https://your-domain.com/paytech/ipn-callback"
PAYTECH_SUCCESS_URL="https://your-frontend.com/payment/success"
PAYTECH_CANCEL_URL="https://your-frontend.com/payment/cancel"

# PayDunya Payment Gateway Configuration
# Documentation: https://developers.paydunya.com/doc/FR/introduction
