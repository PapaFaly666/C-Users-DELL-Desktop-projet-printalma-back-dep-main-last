# =====================================================
#  Configuration PayDunya - Prête à l'emploi
# =====================================================
#
# Instructions:
# 1. Copiez ce fichier vers .env : cp .env.paydunya .env
# 2. Modifiez les autres variables (DATABASE_URL, JWT_SECRET, etc.)
# 3. Démarrez l'application : npm run start:dev
# 4. Testez : ./test-paydunya.sh
#
# =====================================================

# =====================================================
# PAYDUNYA CONFIGURATION
# =====================================================

# Master Key (identique pour test et production)
PAYDUNYA_MASTER_KEY="1nMjPuqy-oa01-tJIO-g8J2-u1wfqxtUDnlj"

# =====================================================
# MODE TEST (SANDBOX) - Pour le développement
# =====================================================
# Clés de test (préfixe test_)
PAYDUNYA_PRIVATE_KEY="test_private_uImFqxfqokHqbqHI4PXJ24huucO"
PAYDUNYA_PUBLIC_KEY="test_public_kvxlzRxFxoS2gFO3FhSxtF3Owwt"
PAYDUNYA_TOKEN="BuVS3uuAKsg9bYyGcT9B"
PAYDUNYA_MODE="test"

# URLs pour mode test
PAYDUNYA_CALLBACK_URL="http://localhost:3000/paydunya/callback"
PAYDUNYA_RETURN_URL="http://localhost:3001/payment/success"
PAYDUNYA_CANCEL_URL="http://localhost:3001/payment/cancel"

# =====================================================
# MODE PRODUCTION - Pour la mise en production
# =====================================================
# Décommentez les lignes suivantes pour passer en production
# et commentez les lignes du mode test ci-dessus
#
# PAYDUNYA_PRIVATE_KEY="live_private_qOMBJy26LHbUJr2JNDQ2OJRfoTG"
# PAYDUNYA_PUBLIC_KEY="live_public_JzyUBGQTafgpOPqRulSDGDVfHzz"
# PAYDUNYA_TOKEN="lt8YNn0GPW6DTIWcCZ8f"
# PAYDUNYA_MODE="live"
#
# PAYDUNYA_CALLBACK_URL="https://api.printalma.com/paydunya/callback"
# PAYDUNYA_RETURN_URL="https://printalma.com/payment/success"
# PAYDUNYA_CANCEL_URL="https://printalma.com/payment/cancel"

# =====================================================
# FRONTEND URL
# =====================================================
FRONTEND_URL="http://localhost:3001"
# En production : FRONTEND_URL="https://printalma.com"

# =====================================================
# AUTRES CONFIGURATIONS (à compléter selon votre projet)
# =====================================================

# Database Configuration
DATABASE_URL="postgresql://printalma_user:printalma_password@localhost:5432/printalma_db?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# Cloudinary Configuration
CLOUDINARY_CLOUD_NAME="your-cloudinary-cloud-name"
CLOUDINARY_API_KEY="your-cloudinary-api-key"
CLOUDINARY_API_SECRET="your-cloudinary-api-secret"

# SMTP Configuration for emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"

# Redis Configuration
REDIS_PASSWORD="redis_password"     

# Application Configuration
NODE_ENV="development"
PORT="3000"

# Security
CORS_ORIGIN="http://localhost:3001"

# =====================================================
# PAYTECH (DEPRECATED) - Garde pour compatibilité
# =====================================================
# Vous pouvez garder ces variables si vous souhaitez
# maintenir PayTech en parallèle pendant la transition
#
# PAYTECH_API_KEY="your-paytech-api-key"
# PAYTECH_API_SECRET="your-paytech-api-secret"
# PAYTECH_ENVIRONMENT="test"
# PAYTECH_IPN_URL="https://your-domain.com/paytech/ipn-callback"
# PAYTECH_SUCCESS_URL="https://your-frontend.com/payment/success"
# PAYTECH_CANCEL_URL="https://your-frontend.com/payment/cancel"

# =====================================================
# NOTES IMPORTANTES
# =====================================================
#
# 1. SÉCURITÉ:
#    - Ne JAMAIS committer ce fichier dans Git
#    - Ajouter .env dans .gitignore
#    - Utiliser des secrets managers en production
#
# 2. MODE TEST vs PRODUCTION:
#    - Test: Utilisez les clés avec préfixe test_
#    - Production: Utilisez les clés avec préfixe live_
#    - Changez PAYDUNYA_MODE selon l'environnement
#
# 3. WEBHOOKS:
#    - Les URLs de callback doivent être HTTPS en production
#    - Configurez l'URL de callback dans le dashboard PayDunya
#    - Testez les webhooks avec ngrok en local si nécessaire
#
# 4. URLS:
#    - Callback: Backend endpoint pour recevoir les notifications
#    - Return: Frontend page après paiement réussi
#    - Cancel: Frontend page après annulation
#
# 5. TESTS:
#    - Testez avec: ./test-paydunya.sh
#    - Vérifiez la config: curl http://localhost:3000/paydunya/test-config
#
# =====================================================
# DOCUMENTATION
# =====================================================
#
# - Démarrage rapide: PAYDUNYA_QUICKSTART.md
# - Guide complet: PAYDUNYA_MIGRATION_GUIDE.md
# - Implémentation: PAYDUNYA_IMPLEMENTATION.md
# - README: PAYDUNYA_README.md
#
# Support PayDunya: [email protected]
# Documentation API: https://developers.paydunya.com/doc/FR/introduction
#
# =====================================================
